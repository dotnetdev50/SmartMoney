{
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\MSSQLLocalDB;Database=SmartMoney_Dev;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Nse": {
    "ArchivesBaseUrl": "https://archives.nseindia.com/content/nsccl/",
    "ParticipantOiTemplate": "fao_participant_oi_{ddMMyyyy}.csv",
    "RequestTimeoutSeconds": 30
  },
  "NseJob": {
    "Enabled": true,
    "StartAtIst": "20:05",
    "EndAtIst": "22:00",
    "RetryMinutes": 15,
    "ExpectedParticipantRowsPerDay": 4
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "SmartMoney.Application.Services.CsvIngestionService": "Information",
      "SmartMoney.Application.Services.DailyPipelineService": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}